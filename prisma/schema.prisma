generator client {
  provider = "prisma-client-js"
 
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id    String  @id @default(uuid())
  email String  @unique
  name  String?
  
  orders Orders[]
}

model Orders {
  id          String   @id @default(cuid())
  title       String
  Delivered Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  userId      String
}
model Sellers{
  id          String   @id @default(cuid())
  email String  @unique
  name  String?
}
model Admin{
id          String   @id @default(cuid())
email String  @unique
name  String?
}